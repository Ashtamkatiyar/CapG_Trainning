<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd
       http://www.springframework.org/schema/context
       http://www.springframework.org/schema/context/spring-context.xsd">

     <context:annotation-config/>

     <!-- Employee Bean -->
     <bean id="employee" class="org.example.Employee">
          <property name="empid" value="105"/>
          <property name="name" value="Switi"/>
     </bean>

     <!-- Address Dependency 1 -->
     <bean id="add" class="org.example.Address">
          <property name="city" value="Delhi"/>
          <property name="country" value="India"/>
          <property name="zip" value="110001"/>
     </bean>

     <!-- Address Dependency 2 -->
     <bean id="add2" class="org.example.Address">
          <property name="city" value="Mumbai"/>
          <property name="country" value="India"/>
          <property name="zip" value="400001"/>
     </bean>



</beans>