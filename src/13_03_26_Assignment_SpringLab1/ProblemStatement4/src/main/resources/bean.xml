<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
 http://www.springframework.org/schema/beans
 http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Employee Beans -->

    <bean id="emp1" class="org.example.Employee">
        <property name="employeeId" value="100"/>
        <property name="employeeName" value="Rama"/>
        <property name="salary" value="12345.67"/>
    </bean>

    <bean id="emp2" class="org.example.Employee">
        <property name="employeeId" value="101"/>
        <property name="employeeName" value="Krishna"/>
        <property name="salary" value="20000"/>
    </bean>

    <!-- Service Bean -->

    <bean id="service" class="org.example.EmployeeService">

        <property name="employeeMap">

            <map>

                <entry key="100" value-ref="emp1"/>
                <entry key="101" value-ref="emp2"/>

            </map>

        </property>

    </bean>

</beans>