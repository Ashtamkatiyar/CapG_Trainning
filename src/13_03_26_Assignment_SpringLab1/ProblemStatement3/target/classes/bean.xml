<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
 http://www.springframework.org/schema/beans
 http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Employee Beans -->

    <bean id="emp1" class="org.example.Employee">
        <property name="employeeId" value="101"/>
        <property name="employeeName" value="Rahul"/>
        <property name="salary" value="30000"/>
    </bean>

    <bean id="emp2" class="org.example.Employee">
        <property name="employeeId" value="102"/>
        <property name="employeeName" value="Ankit"/>
        <property name="salary" value="35000"/>
    </bean>

    <!-- SBU Bean -->

    <bean id="sbu" class="org.example.SBU">

        <property name="sbuId" value="1"/>
        <property name="sbuName" value="PES"/>
        <property name="sbuHead" value="Kiran Rao"/>

        <property name="empList">
            <list>
                <ref bean="emp1"/>
                <ref bean="emp2"/>
            </list>
        </property>

    </bean>

</beans>